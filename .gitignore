### VS Code
# Keep shared VSCode configuration.
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.history/
*.vsix

# Local analysis and generated deployment output
/.tools/
/.wrangler/
/MCPShots/
/_external/
/BuildAssetBundles/
/Deploy/AssetServer/
/Deploy/asset-server-url-*.txt
/Deploy/*.pid
/Deploy/*.log
/bak.tsv
/cur.tsv
/buttons_compare.txt

# Unity plugin binaries must be versioned when they live under Assets/Plugins.
!/[Aa]ssets/[Pp]lugins/**/*.dll
!/[Aa]ssets/[Pp]lugins/**/*.pdb
!/[Aa]ssets/[Pp]lugins/**/*.mdb
!/[Aa]ssets/[Pp]lugins/**/*.so
!/[Aa]ssets/[Pp]lugins/**/*.dylib
!/[Aa]ssets/[Pp]lugins/**/*.a
!/[Aa]ssets/[Pp]lugins/**/*.lib
!/[Aa]ssets/[Pp]lugins/**/*.aar
!/[Aa]ssets/[Pp]lugins/**/*.jar

# Keep Unity package manifests reproducible.
!/[Pp]ackages/manifest.json
!/[Pp]ackages/packages-lock.json
!/[Pp]roject[Ss]ettings/[Pp]ackages/
!/[Pp]roject[Ss]ettings/[Pp]ackages/**

# Keep embedded Unity/UTAGE package dependencies.
!/[Aa]ssets/[Uu]tage/[Ee]ditor/[Ee]xcel[Pp]arser/NPOI/**/*.dll
!/[Aa]ssets/[Uu]tage/[Ee]ditor/[Ee]xcel[Pp]arser/NPOI/**/*.dll.meta
!/[Aa]ssets/[Uu]tage/[Ee]xtension[Ss]upport/[Rr]ender[Pp]ipelines/[Pp]ackages/
!/[Aa]ssets/[Uu]tage/[Ee]xtension[Ss]upport/[Rr]ender[Pp]ipelines/[Pp]ackages/**
